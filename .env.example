# VistaFam Enterprise Environment Configuration
# Copy to .env and fill in your values

# ── Infrastructure ──────────────────────────────────────────

# PostgreSQL
POSTGRES_PASSWORD=vistafam_secure_password
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5432/vistafam

# Redis
REDIS_URL=redis://localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# MinIO (S3-compatible storage)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ENDPOINT=localhost:9000

# ── Authentication ────────────────────────────────────────────

# JWT Keys (generate with: openssl genrsa -out private.pem 2048)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# AuthSphere
AUTHSPHERE_URL=http://localhost:4001

# ── AI Providers (at least one required) ──────────────────────

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
DEEPSEEK_API_KEY=sk-...

# Ollama (optional, for local inference)
OLLAMA_URL=http://localhost:11434

# ── Legacy Supabase (optional, for migration) ────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"

# ── VistaFam Core ───────────────────────────────────────────
NODE_ENV=development

# Web Apps
NEXT_PUBLIC_API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# API Server
API_PORT=4000
API_HOST=0.0.0.0

# ── TeamSync ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SFU (Voice/Video)
SFU_PROVIDER=livekit
SFU_URL=wss://your-sfu.livekit.cloud
SFU_API_KEY=your-sfu-key

# Push Notifications
FCM_SERVER_KEY=your-fcm-server-key

# ── Grafana ─────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme-strong-password

# ── Hetzner Object Storage (Backups) ────────────────────────
# S3-compatible endpoint for backups
# AWS_ACCESS_KEY_ID=your-hetzner-access-key
# AWS_SECRET_ACCESS_KEY=your-hetzner-secret-key
# AWS_DEFAULT_REGION=fsn1
# AWS_ENDPOINT_URL_S3=https://fsn1.your-objects.com

# ── Production Overrides (set in .env.production) ───────────
# These are defaults for local development.
# Production values go in .env.production (NOT committed).
# See docker-compose.production.yml for the full production stack.
