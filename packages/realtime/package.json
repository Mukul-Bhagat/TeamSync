{
  "name": "@vistafam/realtime",
  "version": "0.1.0",
  "private": true,
  "description": "VistaFam realtime client - Socket.IO + Redis adapter wrapper",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
