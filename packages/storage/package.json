    "@aws-sdk/lib-storage": "^3.600.0",
    "mime-types": "^2.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "eslint": "^8.0.0"
  }
}
