{
  "name": "@vistafam/storage",
  "version": "0.1.0",
  "private": true,
  "description": "VistaFam storage client - MinIO/S3 abstraction with presigned URLs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
