{
  "name": "@vistafam/hooks",
  "version": "0.1.0",
  "private": true,
  "description": "VistaFam React hooks - data fetching, realtime, auth",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@vistafam/types": "workspace:*",
    "@vistafam/store": "workspace:*",
    "@vistafam/database": "workspace:*",
    "@vistafam/auth": "workspace:*",
    "@tanstack/react-query": "^5.50.0",
    "react": "^19.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "eslint": "^8.0.0"
  }
}
