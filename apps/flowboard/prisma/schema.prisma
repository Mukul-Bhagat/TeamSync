generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Workflow Definitions ──────────────────────────────────

model Workflow {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  status      String   @default("draft") // draft, active, paused, archived
  version     Int      @default(1)
  definition  Json     // full DAG: steps, triggers, variables
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  triggers    WorkflowTrigger[]
  executions  Execution[]
  variables   Variable[]
  kanbanBoards KanbanBoard[]

  @@index([tenantId, status])
  @@index([tenantId, name])
  @@map("workflows")
}

// ── Workflow Triggers ───────────────────────────────────────

model WorkflowTrigger {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowId String   @map("workflow_id") @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  type       String   // event, cron, webhook, manual
  config     Json
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([tenantId, type, isActive])
  @@index([workflowId])
  @@map("workflow_triggers")
}

// ── Executions ────────────────────────────────────────────

model Execution {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  workflowId        String   @map("workflow_id") @db.Uuid
  triggerType       String   @map("trigger_type")
  triggerEvent      Json?    @map("trigger_event")
  triggerMetadata   Json?    @map("trigger_metadata")
  status            String   @default("pending") // pending, running, completed, failed, cancelled, paused
  currentStepId     String?  @map("current_step_id")
  context           Json     @default("{}")
  input             Json?
  output            Json?
  error             Json?
  startedAt         DateTime? @map("started_at")
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime @default(now()) @map("created_at")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  steps    ExecutionStep[]
  logs     ExecutionLog[]
  approvals Approval[]
  tasks    Task[]
  comments ExecutionComment[]

  @@index([tenantId, workflowId, status])
  @@index([tenantId, status])
  @@index([workflowId, createdAt])
  @@map("executions")
}

// ── Execution Steps ───────────────────────────────────────

model ExecutionStep {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  executionId String    @map("execution_id") @db.Uuid
  stepId      String    @map("step_id")
  stepType    String    @map("step_type")
  status      String    @default("pending") // pending, running, completed, failed, skipped, waiting_approval
  input       Json?
  output      Json?
  error       Json?
  retryCount  Int       @default(0) @map("retry_count")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  execution Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, stepId])
  @@index([executionId, status])
  @@map("execution_steps")
}

// ── Execution Logs ────────────────────────────────────────

model ExecutionLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  executionId String   @map("execution_id") @db.Uuid
  stepId      String?  @map("step_id")
  level       String
  message     String
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  execution Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, createdAt])
  @@map("execution_logs")
}

// ── Variables ─────────────────────────────────────────────

model Variable {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowId String? @map("workflow_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  key       String
  value     Json?
  isSecret  Boolean  @default(false) @map("is_secret")
  createdAt DateTime @default(now()) @map("created_at")

  workflow Workflow? @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([tenantId, workflowId, key])
  @@index([tenantId, key])
  @@map("variables")
}

// ── Approvals ───────────────────────────────────────────

model Approval {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  executionId  String   @map("execution_id") @db.Uuid
  stepId       String   @map("step_id")
  tenantId     String   @map("tenant_id") @db.Uuid
  status       String   @default("pending") // pending, approved, rejected, expired
  approvers    String[] @db.Uuid
  approvedBy   String?  @map("approved_by") @db.Uuid
  comment      String?
  deadline     DateTime?
  createdAt    DateTime @default(now()) @map("created_at")
  respondedAt  DateTime? @map("responded_at")

  execution Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([executionId, stepId])
  @@map("approvals")
}

// ── Workflow Templates ──────────────────────────────────

model WorkflowTemplate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  category    String // onboarding, devops, security, analytics
  definition  Json
  isBuiltin   Boolean  @default(false) @map("is_builtin")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([category])
  @@map("workflow_templates")
}

// ── Kanban Boards ────────────────────────────────────────

model KanbanBoard {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  name       String
  workflowId String?  @map("workflow_id") @db.Uuid
  columns    Json     @default("[{\"id\":\"todo\",\"name\":\"To Do\"},{\"id\":\"in_progress\",\"name\":\"In Progress\"},{\"id\":\"done\",\"name\":\"Done\"}]")
  createdAt  DateTime @default(now()) @map("created_at")

  workflow Workflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  tasks    Task[]

  @@index([tenantId, workflowId])
  @@map("kanban_boards")
}

// ── Tasks (Kanban) ───────────────────────────────────────

model Task {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  executionId String?   @map("execution_id") @db.Uuid
  stepId      String?   @map("step_id")
  title       String
  description String?
  status      String    @default("todo") // todo, in_progress, done, blocked, cancelled
  assigneeId  String?   @map("assignee_id") @db.Uuid
  priority    String    @default("medium") // low, medium, high, urgent
  dueDate     DateTime? @map("due_date")
  tags        String[]
  boardId     String?   @map("board_id") @db.Uuid
  position    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  execution Execution?  @relation(fields: [executionId], references: [id], onDelete: SetNull)
  board     KanbanBoard? @relation(fields: [boardId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, assigneeId])
  @@index([boardId, position])
  @@map("tasks")
}

// ── Execution Comments ──────────────────────────────────

model ExecutionComment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  executionId String   @map("execution_id") @db.Uuid
  authorId    String   @map("author_id") @db.Uuid
  content     String
  mentions    String[] @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  execution Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, createdAt])
  @@map("execution_comments")
}

// ── Audit Log ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  workflowId  String?  @map("workflow_id") @db.Uuid
  executionId String?  @map("execution_id") @db.Uuid
  action      String
  actorId     String?  @map("actor_id") @db.Uuid
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, action])
  @@index([tenantId, createdAt])
  @@map("audit_log")
}
